# Project Wasto — Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# Backend API URL
VITE_API_URL=http://localhost:8000/api/v1

# OpenWeatherMap API Key (free tier at openweathermap.org)
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Default city for weather forecasts
VITE_DEFAULT_CITY=Quezon City
VITE_DEFAULT_LAT=14.6760
VITE_DEFAULT_LON=121.0437

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id


