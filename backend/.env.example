SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_NAME=wasto_db
DATABASE_USER=postgres
DATABASE_PASSWORD=yourpassword
DATABASE_HOST=localhost
DATABASE_PORT=5432
OPENWEATHERMAP_API_KEY=your-openweathermap-key
FIREBASE_SERVER_KEY=your-firebase-server-key

# ── Google Calendar Integration ──────────────────────────────────────────────
# Option A: Path to service account JSON file (local dev)
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/your/service-account.json
# Option B: Service account JSON as a single-line string (for deployment/CI)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# The Google Calendar ID to write schedules into.
# Use "primary" for the service account's own calendar, or paste the calendar
# ID of a shared calendar (e.g. abc123@group.calendar.google.com).
# IMPORTANT: Share this calendar with the service account email as "Make changes to events".
GOOGLE_CALENDAR_ID=primary

# ── Setup Instructions ────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create/select a project → APIs & Services → Enable "Google Calendar API"
# 3. IAM & Admin → Service Accounts → Create → download JSON key
# 4. Set GOOGLE_SERVICE_ACCOUNT_FILE to the path of that JSON key
# 5. In Google Calendar, open calendar Settings → Share with specific people
#    → add the service account email with "Make changes to events" permission
# 6. Copy the Calendar ID from Settings → Integrate calendar → set GOOGLE_CALENDAR_ID
